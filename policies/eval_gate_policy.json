{
  "version": "1.0",
  "description": "CI eval gate thresholds — PRs that regress below these are blocked",
  "thresholds": {
    "classifier": { "min_accuracy": 0.90 },
    "line_items": { "min_accuracy": 0.85 },
    "recovery": { "min_accuracy": 0.80 }
  },
  "regression_tolerance": 0.02,
  "require_baseline_update_on_improvement": false
}
