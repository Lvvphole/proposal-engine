# Frontend environment configuration (Next.js on Vercel).
#
# The browser calls same-origin `/api/*`; next.config.js rewrites proxy those
# requests to the backend. Point this at the deployed backend API URL.
#
# Local dev (default if unset): http://localhost:8000
API_PROXY_TARGET=https://your-backend.example.com

# Alternative name honored by next.config.js if API_PROXY_TARGET is unset.
# NEXT_PUBLIC_API_URL=https://your-backend.example.com
