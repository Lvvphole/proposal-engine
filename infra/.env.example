# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Database — Supabase Postgres (managed).
# Paste the connection string from Supabase → Project Settings → Database.
# The app auto-normalises `postgresql://` to the asyncpg driver and enables
# TLS for *.supabase.co / *.supabase.com hosts, so either form works:
#
#   Direct:  postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#   Pooler:  postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Use the pooler (port 6543) for serverless/many-connection deployments.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── LLM Configuration ────────────────────────────────────
DEFAULT_MODEL=claude-sonnet-4-20250514
CLASSIFIER_MODEL=claude-haiku-3-5-20241022
EXTRACTION_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4096

# ── Budget Limits ─────────────────────────────────────────
BUDGET_DAILY_LIMIT_USD=25.00
BUDGET_PER_ENVELOPE_LIMIT_USD=2.00

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Allowed CORS origins (comma-separated). Set to the Vercel frontend URL
# in production, e.g. https://proposal-engine.vercel.app
CORS_ORIGINS=http://localhost:3000

# ── Auth (Supabase JWT) ───────────────────────────────────
# When false (default), the API is unauthenticated (local dev / tests).
# In production set AUTH_ENABLED=true and the Supabase project's JWT secret
# (Supabase → Project Settings → API → JWT Secret). Requires the frontend to
# send the user's Supabase access token as a Bearer header.
AUTH_ENABLED=false
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# ── MCP Server ────────────────────────────────────────────
MCP_SERVER_PORT=3100
